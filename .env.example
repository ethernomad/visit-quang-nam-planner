# Visit Quang Nam AI Trip Planner — environment variables.
#
# Copy to `.env` and fill in the keys. Never commit `.env`.
# Auto-loaded by `dotenvy` on server boot (`dx serve`, `cargo run --bin
# build_corpus`, tests). Process-supplied env vars always win.
# The runtime consults exactly these variables (verified against src/):
#   - src/ingest/embedder.rs  reads OPENAI_API_KEY
#   - src/server/llm.rs       reads OPENCODE_API_KEY (+ BASE_URL, MODEL)
#   - src/server/mod.rs       reads CORPUS_PATH
#   - dioxus-cli-config       reads PORT

# Required for build_corpus (one-time corpus build) AND for query-time
# embeddings at runtime (InMemoryRetriever embeds each user query via OpenAI
# text-embedding-3-small). OpenCode Zen has no /embeddings endpoint, so this
# must be a real OpenAI key.
OPENAI_API_KEY=

# Required at runtime for the planner LLM. Chat completions go to OpenCode Zen
# (an OpenAI-chat-compatible endpoint) using opencode/big-pickle. Without this
# key, /api/plan-trip returns a 500 "LLM init failed" error.
OPENCODE_API_KEY=

# Optional. Zen stealth endpoint. Override to re-point the planner at real
# OpenAI (or any OpenAI-chat-compatible base URL).
# Default: https://opencode.ai/zen/v1
# OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# Optional. Chat model on the configured base URL.
# Default: opencode/big-pickle
# OPENCODE_MODEL=opencode/big-pickle

# Optional. Path to the committed RAG corpus (chunks + embeddings cache).
# Default: data/corpus.json
# CORPUS_PATH=data/corpus.json

# Optional. Port the axum server binds. Default: 8080
# PORT=8080
